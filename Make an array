#include<bits/stdc++.h>
using namespace std;
int solve (int N, vector<int> A) {
   // Write your code here
   long long k;
   long long sum=0;
   int i;
   for(i=0;i<N;i++)
   {
    sum+=A[i];
   }
   k=sum/(N-1);
   for(i=0;i<N;i++)
   {
    if(A[i]>k)
    {
        return -1;
    }
   }
   if(sum%(N-1)==0)
   {
    return k;
   }
   else
   {
    return -1;
   }
   
    
}

int main() {

    ios::sync_with_stdio(0);
    cin.tie(0);
    int T;
    cin >> T;
    for(int t_i = 0; t_i < T; t_i++)
    {
        int N;
        cin >> N;
        vector<int> A(N);
        for(int i_A = 0; i_A < N; i_A++)
        {
        	cin >> A[i_A];
        }

        int out_;
        out_ = solve(N, A);
        cout << out_;
        cout << "\n";
    }
}
