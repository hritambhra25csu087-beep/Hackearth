#include<iostream>
#include<algorithm>
using namespace std;
int main()
{
	long long X,N,T;
	cin>>T;
	while(T--)
	{
		cin>>N;
		cin>>X;
		long long A[N];
		for(int i=0;i<N;i++)
		{
			cin>>A[i];
		}
		long long  count=0;
        long long  CurrentMin;
        long long CurrentMax;
		for(int i=0;i<N;i++)
		{
			 CurrentMin=A[i];
			 CurrentMax=A[i];
			for(int j=i;j<N;j++)
			{
				CurrentMin=min(CurrentMin,A[j]);
			    CurrentMax=max(CurrentMax,A[j]);
				if((CurrentMin+CurrentMax)<=X)
				{
					count++;
				}

			}
		}
		cout<<count<<endl;
	}
	return 0;
}
