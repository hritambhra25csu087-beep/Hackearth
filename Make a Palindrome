#include<iostream>
using namespace std;
int main() {
    int t;
    cin>>t;
    while(t--)
    {
	int num;
	cin >> num;    //Reading input from STDIN
    string s;
    cin>>s;
    int freq[26]={0};
    for(int i=0;i<num;i++)
    {
        freq[s[i]-'a']++;
    }
    int odd=0;
    for(int i=0;i<26;i++)
    {
        if(freq[i]%2!=0)
        {
            odd++;
       }    
   }
    if(odd==0)
    {cout<<0;}
    else
    {
        cout<<odd-1;
    }
    }
    return 0;
    }


       
